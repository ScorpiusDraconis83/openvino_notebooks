#!/bin/bash

set -eo pipefail

# Test that jupyterhub and ovmsclient imports work (required for image to work in RedHat cluster)
python -c "from jupyterhub.singleuser.mixins import make_singleuser_app"
python -c "import ovmsclient"

# Required for PaddlePaddle
export HUB_HOME=/tmp

# Move notebooks for validation
cp -R /opt/app-root/openvino_notebooks/notebooks /tmp/
# Download CT scan image for 110 training notebook
mkdir -p /tmp/notebooks/110-ct-segmentation-quantize/kits19
cd /tmp/notebooks/110-ct-segmentation-quantize/kits19
curl -O -C - https://storage.openvinotoolkit.org/data/test_data/openvino_notebooks/kits19/case_00030.zip
unzip case_00030.zip
mkdir kits19_frames
mv case_00030 kits19_frames
cp -r kits19_frames/case_00030 kits19_frames/case_00001

cd "/tmp"
# Patch notebooks to speed up test execution
python /tmp/scripts/patch_notebooks.py /tmp/notebooks

# Install CI requirements
pip install -r /opt/app-root/openvino_notebooks/.ci/ci-requirements.txt

# The base workbench image may ship optimum/optimum-intel in /opt/app-root.
# Purge them from the base venv BEFORE cloning so every per-notebook clone starts
# clean and the only optimum present is the one the notebook installs itself.
# This prevents duplicate dist-info ("conflicting subparser: openvino").
pip uninstall -q -y optimum optimum-intel optimum-onnx || true

# Test notebooks
# Run every notebook in its own cloned virtual environment so that per-notebook
# pip installs cannot leak into the shared image environment (which otherwise
# leaves duplicated/incompatible distributions, e.g. multiple "optimum" copies
# or transformers/diffusers version skew, breaking subsequent notebooks).
python /tmp/scripts/validate_notebooks.py \
    --ignore_list /tmp/scripts/ignore_treon_docker.txt \
    --test_list /tmp/scripts/test_notebooks.txt \
    --separate_venv \
    --source_venv_path /opt/app-root \
    --cleanup_temp
